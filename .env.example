NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=ricealteromegorto

DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

EMBEDDING_BACKEND=offline  # offline 或 sbert
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
FAISS_INDEX_PATH=data/go_faiss.index
FAISS_METADATA_PATH=data/go_metadata.json
TOP_K=5

# SapBERT 配置（本地模型路径）
SAPBERT_EMBEDDING_MODEL_NAME=models/SapBERT-from-PubMedBERT-fulltext
SAPBERT_FAISS_INDEX_PATH=data/go_faiss_sapbert.index
SAPBERT_FAISS_METADATA_PATH=data/go_metadata_sapbert.json
